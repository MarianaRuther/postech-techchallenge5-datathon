# ============================================
# .gitignore — Datathon FIAP Fase 5
# ============================================

# Ambiente virtual
.venv/
venv/
env/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDEs
.cursor/
.vscode/
.idea/
*.code-workspace

# Jupyter
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ============================================
# Dados — privacidade dos alunos da Passos
# ============================================
# Dataset original (não distribuir publicamente)
data/raw/

# Caches regeneráveis (parquets, embeddings, OCR)
data/interim/
data/processed/

# ============================================
# Material auxiliar do curso (não é projeto)
# ============================================
Aula*.pdf
Cap Projeto*.pdf

# ============================================
# Checkpoints / progresso pessoal (não vai pro repo)
# ============================================
_PROGRESS.md
*.autopilot.json

# ============================================
# Logs e artefatos volumosos
# ============================================
*.log
*.tmp

# ============================================
# Modelos: permitidos (são leves) — manter modelo final, MLP, jsons
# ============================================
# models/*.pkl, *.pt, *.json — versionados (úteis pro app e pra reprodutibilidade)
